# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://xtox.app

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/xtox

# ── Email (Gmail App Password for OTP & notifications) ───────────────────────
EMAIL_USER=xtox.noreply@gmail.com
EMAIL_PASS=cbrh bngn shsh zajm

# ── OpenAI — WhatsApp chatbot (OPENAI_API_KEY) ───────────────────────────────
# Used by: backend/routes/whatsapp.js for intelligent Arabic chatbot replies
OPENAI_API_KEY=<your-openai-api-key>

# ── OpenAI — Ad content moderation (OPENAI_ANALYSIS_KEY) ─────────────────────
# Used by: backend/utils/adModeration.js for AI-powered ad content analysis
# Flags inappropriate/fraudulent ads for review before they go live
OPENAI_ANALYSIS_KEY=<your-openai-analysis-key>

# ── Cloudinary (optional — images stored as base64 when not configured) ───────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── WhatsApp / UltraMsg (optional) ───────────────────────────────────────────
ULTRAMSG_INSTANCE=your_instance_id
ULTRAMSG_TOKEN=your_token
WHATSAPP_WEBHOOK_TOKEN=your_webhook_secret

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Stripe (optional — for featured ads payments) ────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
