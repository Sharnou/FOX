{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "github": {
    "enabled": true,
    "silent": false
  },
  "regions": ["iad1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  }
}
