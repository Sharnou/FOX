# ============================================================
# XTOX Backend — Required Environment Variables (Railway)
# ============================================================
# Copy this file to .env for local development.
# In Railway: Settings → Variables → Add each var below.
# ============================================================

# -- Email OTP -------------------------------------------------------
# Gmail address used to send OTP codes to users.
# IMPORTANT: The Gmail address is not yet known — ask the project owner.
# Use a dedicated Gmail account (e.g. xtox.noreply@gmail.com).
EMAIL_USER=your-gmail@gmail.com

# Gmail App Password (16 chars, spaces OK).
# Generate at: myaccount.google.com → Security → App Passwords
# (Requires 2-Step Verification to be enabled)
EMAIL_PASS=xxxx xxxx xxxx xxxx

# -- OpenAI (WhatsApp chatbot intelligence) --------------------------
# Powers the Arabic AI assistant. Without this, chatbot uses static
# hardcoded replies (still functional, just not AI-powered).
OPENAI_API_KEY=sk-...

# -- UltraMsg (WhatsApp message sending) -----------------------------
# Required for the chatbot to actually SEND WhatsApp replies.
# Create at: ultramsg.com → My Instances → Create Instance
# Set the UltraMsg webhook URL to: POST /api/whatsapp/webhook
ULTRAMSG_INSTANCE=instance12345
ULTRAMSG_TOKEN=your-ultramsg-token

# Optional: validate incoming UltraMsg webhook calls
# Set this to a random secret and configure it in the UltraMsg dashboard
WHATSAPP_WEBHOOK_TOKEN=

# -- MongoDB ---------------------------------------------------------
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/xtox

# -- JWT -------------------------------------------------------------
JWT_SECRET=your-long-random-secret-here

# -- Google OAuth (Sign-In with Google) ------------------------------
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=https://xtox-production.up.railway.app/api/auth/google/callback

# -- Apple Sign In ---------------------------------------------------
APPLE_CLIENT_ID=com.xtox.app

# -- Cloudinary (Image uploads) --------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -- App Config ------------------------------------------------------
FRONTEND_URL=https://fox-kohl-eight.vercel.app
NODE_ENV=production
PORT=3001

# -- Admin -----------------------------------------------------------
ADMIN_BLOCK_SECRET=xtox-admin-block

# -- WhatsApp Meta Cloud API (alternative to UltraMsg) --------------
# Leave empty if using UltraMsg instead
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
