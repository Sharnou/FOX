# ─── XTOX Backend — Environment Variables Reference ───────────────────────────
# Copy this to .env.local and fill in your values
# All vars are OPTIONAL — the server runs with in-memory store and rule-based AI if none are set

# ── MongoDB (required for production; omit to use in-memory store) ────────────
# If not set, the server waits 8s then activates the in-memory fallback
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/xtox

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-secret-here-min-32-chars

# ── Cloudinary (image uploads; omit to skip image storage) ───────────────────
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_KEY=your-cloudinary-api-key
CLOUD_SECRET=your-cloudinary-api-secret

# ── AI: Gemini (ad quality scoring; falls back to Ollama → rule-based) ───────
GEMINI_API_KEY=your-google-gemini-api-key

# ── AI: Ollama (local LLM fallback; run: ollama pull llama3) ─────────────────
# Only active when OLLAMA_URL is explicitly set
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id

# ── Couchbase (optional — app works without it) ───────────────────────────────
COUCHBASE_URL=couchbases://your-cluster.cloud.couchbase.com
COUCHBASE_USERNAME=your-username
COUCHBASE_PASSWORD=your-password

# ── Redis (optional — app works without it) ───────────────────────────────────
# Must start with redis:// or rediss:// — invalid URLs are auto-cleared on boot
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
